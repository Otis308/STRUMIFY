# ================================================================
#  Strumify .gitignore
# ================================================================

# ── SECRETS – TUYỆT ĐỐI KHÔNG ĐẨY LÊN GITHUB ──────────────────
.env
*.env
.env.local
.env.production

# ── PYTHON ───────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
*.egg

# ── VIRTUAL ENV ──────────────────────────────────────────────────
venv/
.venv/
env/
ENV/

# ── IDE ──────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── VERCEL ───────────────────────────────────────────────────────
.vercel/

# ── LOGS ─────────────────────────────────────────────────────────
*.log
logs/